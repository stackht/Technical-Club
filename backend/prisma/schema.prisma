generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  phone        String
  year         String
  branch       String
  createdAt    DateTime @default(now())
  challenges   UserChallenge[]
}

model OtpToken {
  id         String   @id @default(cuid())
  email      String
  otpHash    String
  phone      String
  year       String
  branch     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  verifiedAt DateTime?
  consumedAt DateTime?

  @@index([email, createdAt])
}

model UserChallenge {
  id         String   @id @default(cuid())
  userId     String
  statementId Int
  statement String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}
