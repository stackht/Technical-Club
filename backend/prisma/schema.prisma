generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  username     String   @unique
  passwordHash String
  phone        String
  year         String
  branch       String
  sScore       Int?
  pScore       Int?
  dScore       Int?
  reviewStatus String   @default("PENDING")
  createdAt    DateTime @default(now())
  challenges   UserChallenge[]
}

model OtpToken {
  id         String   @id @default(cuid())
  name       String
  email      String
  otpHash    String
  phone      String
  year       String
  branch     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  verifiedAt DateTime?
  consumedAt DateTime?

  @@index([email, createdAt])
}

model UserChallenge {
  id         String   @id @default(cuid())
  userId     String
  statementId Int
  statement String
  createdAt  DateTime @default(now())
  releasedAt DateTime?

  user User @relation(fields: [userId], references: [id])
  uploads ChallengeUpload[]

  @@index([userId, createdAt])
}

model ChallengeUpload {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  filename    String
  mimeType    String
  size        Int
  data        Bytes
  createdAt   DateTime @default(now())

  user      User         @relation(fields: [userId], references: [id])
  challenge UserChallenge @relation(fields: [challengeId], references: [id])

  @@index([userId, createdAt])
  @@index([challengeId, createdAt])
}
